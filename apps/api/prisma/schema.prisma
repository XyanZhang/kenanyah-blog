generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum AdminRole {
  ADMIN
}

enum AuthProvider {
  local
  google
  github
}

enum VerificationCodeType {
  LOGIN
  REGISTER
  RESET_PASSWORD
}

enum EventSourceType {
  manual
  post
  thought
  project
  photo
  system
}

enum EventStatus {
  planned
  completed
  canceled
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  username      String       @unique
  passwordHash  String?
  name          String?
  bio           String?
  avatar        String?
  role          UserRole     @default(USER)
  provider      AuthProvider @default(local)
  providerId    String?
  emailVerified DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  posts              Post[]
  comments           Comment[]
  countdownEvents    CountdownEvent[]
  calendarAnnotations CalendarAnnotation[]
  thoughts            Thought[]
  projectEntries      ProjectEntry[]
  photoEntries        PhotoEntry[]
  eventItems          EventItem[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([isActive])
  @@map("admin_users")
}

model VerificationCode {
  id        String                @id @default(cuid())
  email     String
  code      String
  type      VerificationCodeType
  attempts  Int                   @default(0)
  expiresAt DateTime
  createdAt DateTime              @default(now())
  usedAt    DateTime?

  @@index([email, type])
  @@index([expiresAt])
  @@map("verification_codes")
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  isFeatured  Boolean  @default(false)
  viewCount   Int      @default(0)
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  categories   PostCategory[]
  tags         PostTag[]
  embeddings   PostEmbedding[]

  @@index([slug])
  @@index([authorId])
  @@index([published])
  @@index([isFeatured])
  @@map("posts")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts PostCategory[]

  @@index([slug])
  @@map("categories")
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts PostTag[]

  @@index([slug])
  @@map("tags")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  approved  Boolean  @default(true)
  postId    String
  authorId  String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

model PostCategory {
  postId     String
  categoryId String
  createdAt  DateTime @default(now())

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("post_categories")
}

model PostTag {
  postId    String
  tagId     String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// 首页配置：当前布局 + 导航配置，按用户保存（暂时可写死用户 ID，后期关联多用户）
model HomeConfig {
  id         String   @id @default(cuid())
  userId     String?  @unique // 可选，写死用户时用固定 ID；后期必填关联 User
  layoutJson String   @db.Text
  navJson    String   @db.Text
  canvasJson String?  @db.Text
  themeJson  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("home_configs")
}

// 用户倒计时事件（生日、纪念日、考试、活动等），与用户绑定
model CountdownEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  title      String
  targetDate DateTime @map("target_date")
  type       String   // birthday | anniversary | exam | activity
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, targetDate])
  @@map("countdown_events")
}

// 用户日历标注：某日的备注，与用户绑定，用于日历卡片点击日期标注
model CalendarAnnotation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date // 仅日期部分有效
  label     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("calendar_annotations")
}

// 用户保存的「另存为」模板（含 layout + nav 定位与尺寸，应用时一并恢复）
model HomeLayoutTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?  @db.Text
  layoutJson  String   @db.Text
  navJson     String   @db.Text
  canvasJson  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("home_layout_templates")
}

model ChatConversation {
  id             String   @id @default(cuid())
  title          String?
  userId         String?
  isShared       Boolean  @default(false)
  intentStateJson String? @db.Text
  messageCount   Int      @default(0)
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@index([isShared])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model PostEmbedding {
  id         String   @id
  postId     String   @map("post_id")
  chunkIndex Int      @default(0) @map("chunk_index")
  content    String
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], map: "idx_post_embeddings_post_id")
  @@map("post_embeddings")
}

model ConversationEmbedding {
  id             String   @id
  conversationId String   @map("conversation_id")
  content        String   @db.Text
  embedding      Unsupported("vector")
  updatedAt      DateTime @default(now()) @map("updated_at")

  @@index([conversationId], map: "idx_conversation_embeddings_conversation_id")
  @@map("conversation_embeddings")
}

model PdfDocument {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  filename  String
  mimeType  String   @map("mime_type")
  size      Int
  fileUrl   String   @map("file_url")
  status    String   @default("uploaded") // uploaded | parsed | indexed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chunks PdfChunk[]

  @@index([userId])
  @@index([createdAt])
  @@map("pdf_documents")
}

model PdfChunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  chunkIndex Int      @map("chunk_index")
  pageStart  Int?     @map("page_start")
  pageEnd    Int?     @map("page_end")
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  document  PdfDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding PdfChunkEmbedding?

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("pdf_chunks")
}

model PdfChunkEmbedding {
  id         String   @id
  documentId String   @map("document_id")
  chunkId    String   @unique @map("chunk_id")
  chunkIndex Int      @map("chunk_index")
  content    String   @db.Text
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now()) @map("created_at")

  chunk PdfChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([documentId], map: "idx_pdf_chunk_embeddings_document_id")
  @@map("pdf_chunk_embeddings")
}

// 收藏文章：标题、地址、备注，供浏览器插件同步；暂不关联用户
model Bookmark {
  id        String   @id @default(cuid())
  title     String
  url       String   @db.Text
  notes     String?  @db.Text
  category  String?
  tags      Json?    // string[]
  source    String   @default("manual") // browser_extension | manual | api
  favicon   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([url])
  @@index([category])
  @@index([createdAt])
  @@map("bookmarks")
}

// 思考流：类似朋友圈的短文本/图片流
model Thought {
  id           String   @id @default(cuid())
  authorId     String?  @map("author_id")
  content      String   @db.Text
  images       Json?    // string[]
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  author     User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  embeddings ThoughtEmbedding[]

  @@index([authorId])
  @@index([createdAt])
  @@map("thoughts")
}

model ThoughtEmbedding {
  id         String   @id
  thoughtId  String   @map("thought_id")
  chunkIndex Int      @default(0) @map("chunk_index")
  content    String   @db.Text
  embedding  Unsupported("vector(1024)")
  createdAt  DateTime @default(now()) @map("created_at")

  thought Thought @relation(fields: [thoughtId], references: [id], onDelete: Cascade)

  @@index([thoughtId], map: "idx_thought_embeddings_thought_id")
  @@map("thought_embeddings")
}

model ProjectEntry {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  title       String
  description String?  @db.Text
  href        String?  @db.Text
  coverImage  String?  @map("cover_image")
  category    String?
  tags        Json?
  status      String   @default("active")
  startedAt   DateTime? @map("started_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([startedAt])
  @@map("project_entries")
}

model PhotoEntry {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  title       String?
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  takenAt     DateTime? @map("taken_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([takenAt])
  @@map("photo_entries")
}

model EventItem {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  title         String
  description   String?         @db.Text
  sourceType    EventSourceType @map("source_type")
  sourceId      String?         @map("source_id")
  status        EventStatus     @default(planned)
  eventDate     DateTime        @map("event_date")
  endDate       DateTime?       @map("end_date")
  allDay        Boolean         @default(true) @map("all_day")
  entryMethod   String          @default("manual") @map("entry_method")
  autoGenerated Boolean         @default(false) @map("auto_generated")
  payloadJson   Json?           @map("payload_json")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, eventDate])
  @@index([userId, status, eventDate])
  @@index([sourceType, sourceId])
  @@map("event_items")
}
