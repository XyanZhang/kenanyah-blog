# ===========================================
# Production Environment Configuration
# Copy this file to .env.prod and fill in values
# ===========================================

# Environment
NODE_ENV=production

# ===========================================
# Database Configuration
# ===========================================
DB_USER=blog_user
DB_PASSWORD=your-secure-password-here  # CHANGE THIS!
DB_NAME=blog_prod

# ===========================================
# JWT Configuration (REQUIRED)
# Generate secrets with: openssl rand -base64 32
# ===========================================
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# App URLs
# ===========================================
# === IP 访问模式：使用服务器 IP ===
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3001
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP:3000
CORS_ORIGIN=http://YOUR_SERVER_IP:3000
UPLOAD_BASE_URL=http://YOUR_SERVER_IP:3001

# === 域名访问模式：使用域名 ===
# NEXT_PUBLIC_API_URL=https://your-domain.com/api
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# CORS_ORIGIN=https://your-domain.com
# UPLOAD_BASE_URL=https://your-domain.com

NEXT_PUBLIC_APP_NAME=Blog

# ===========================================
# OAuth Configuration (Optional)
# ===========================================
# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_REDIRECT_URI=https://your-domain.com/api/auth/github/callback

# ===========================================
# AI Services (Optional)
# ===========================================
# OpenAI / DeepSeek
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4

# Embeddings (阿里云)
# EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDINGS_API_KEY=your-embeddings-api-key
# EMBEDDINGS_MODEL_NAME=text-embedding-v4

# Dashscope (封面图生成)
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/
# DASHSCOPE_API_KEY=your-dashscope-api-key
# DASHSCOPE_MODEL_NAME=qwen-image-2.0-pro