NODE_ENV=test

# ===========================================
# Server Configuration (只需配置端口)
# ===========================================
WEB_PORT=3000
API_PORT=3001

DB_USER=blog_user
DB_PASSWORD=blog_password
DB_NAME=blog_dev

# ===========================================
# Database Connection
# ===========================================
DATABASE_URL=postgresql://blog_user:blog_password@localhost:5432/blog_dev

# ===========================================
# JWT Configuration (REQUIRED)
# ===========================================
JWT_SECRET=xxx
JWT_REFRESH_SECRET=xxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# App URLs (根据端口自动生成，无需修改)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:${API_PORT}
NEXT_PUBLIC_APP_URL=http://localhost:${WEB_PORT}
CORS_ORIGIN=http://localhost:${WEB_PORT}
UPLOAD_BASE_URL=http://localhost:${API_PORT}

NEXT_PUBLIC_APP_NAME="Blog (Test Env)"

# ===========================================
# AI Services
# ===========================================
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=xxxx
OPENAI_MODEL=deepseek-reasoner

EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDINGS_API_KEY=xxxx
EMBEDDINGS_MODEL_NAME=text-embedding-v4

# ===========================================
# Dashscope (for image generation)
# ===========================================
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=xxxx
DASHSCOPE_MODEL_NAME=qwen-image-2.0-pro

# ===========================================
# Upload
# ===========================================
UPLOAD_DIR=./uploads

# ===========================================
# SMTP Email Service (QQ Mail)
# ===========================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=xxxxx
SMTP_PASS=xxxxx
SMTP_FROM=xxxxx

# ===========================================
# Verification Code Settings
# ===========================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY_MINUTES=10
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_RESEND_COOLDOWN_SECONDS=60