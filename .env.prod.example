NODE_ENV=production

# ===========================================
# Database Configuration
# ===========================================
DB_USER=blog_user
DB_PASSWORD=<YOUR_SECURE_DB_PASSWORD>
DB_NAME=blog_prod

# Preferred runtime images for docker-compose.prod.pull.yml
DOCKER_IMAGE_API=blog-api:latest
DOCKER_IMAGE_WEB=blog-web:latest

# For running Prisma commands on the host machine
# (Docker containers use the DATABASE_URL set in docker-compose.prod.yml)
DATABASE_URL=postgresql://blog_user:<YOUR_SECURE_DB_PASSWORD>@localhost:5432/blog_prod

# ===========================================
# JWT Configuration (REQUIRED)
# Generate secrets with: openssl rand -base64 32
# ===========================================
JWT_SECRET=<YOUR_JWT_SECRET_MIN_32_CHARS>
JWT_REFRESH_SECRET=<YOUR_REFRESH_SECRET_MIN_32_CHARS>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# App URLs
# ===========================================
HOST=https://www.xyan.store
API_UPSTREAM=api:3001
WEB_UPSTREAM=web:3000

NEXT_PUBLIC_APP_NAME="Blog"

# ===========================================
# OAuth Configuration (Optional)
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.xyan.store/auth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://www.xyan.store/auth/callback/github

# ===========================================
# AI Services
# ===========================================
# 兼容 OpenAI 接口的 provider（DeepSeek / Qwen 等）均可接入
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=deepseek-chat

# 按用途模型/Provider 覆盖（可选）：
# - PDF 链路优先速度：deepseek-chat
# - 通用 AI 对话可用更强推理：deepseek-reasoner
OPENAI_MODEL_DEFAULT=deepseek-chat
OPENAI_MODEL_CHAT=deepseek-reasoner
OPENAI_MODEL_PDF=deepseek-chat

# 统一文本聊天厂商路由（invokeChat/streamChat）：openai | qwen
# qwen 使用 DASHSCOPE_API_KEY + DASHSCOPE_BASE_URL 的 compatible-mode（与下方千问文本模型一致）
# LLM_PROVIDER_DEFAULT=openai
# LLM_PROVIDER_FAST=openai
# LLM_PROVIDER_REASONING=qwen

# 如需按用途切不同 provider，可启用以下覆盖（未配置则回退到 OPENAI_BASE_URL / OPENAI_API_KEY）
# OPENAI_BASE_URL_CHAT=https://api.deepseek.com
# OPENAI_API_KEY_CHAT=<YOUR_DEEPSEEK_KEY>
# OPENAI_BASE_URL_PDF=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY_PDF=<YOUR_QWEN_KEY>
# OPENAI_MODEL_PDF=qwen-plus

EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDINGS_API_KEY=<YOUR_EMBEDDINGS_API_KEY>
EMBEDDINGS_MODEL_NAME=text-embedding-v4

# ===========================================
# Dashscope（文生图 + 千问文本 compatible-mode）
# ===========================================
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=<YOUR_DASHSCOPE_API_KEY>
DASHSCOPE_MODEL_NAME=qwen-image-2.0-pro
# 千问文本（OpenAI 兼容 Chat，供 LLM_PROVIDER_*=qwen 或 agent 显式 provider: qwen）
DASHSCOPE_CHAT_MODEL=qwen-turbo
# DASHSCOPE_CHAT_MODEL_FAST=qwen-turbo
# DASHSCOPE_CHAT_MODEL_REASONING=qwen-plus

# ===========================================
# Upload
# ===========================================
UPLOAD_DIR=./uploads

# ===========================================
# SMTP Email Service
# ===========================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<YOUR_EMAIL@qq.com>
SMTP_PASS=<YOUR_SMTP_AUTH_CODE>
SMTP_FROM=<YOUR_EMAIL@qq.com>

# ===========================================
# Verification Code Settings
# ===========================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY_MINUTES=10
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_RESEND_COOLDOWN_SECONDS=60

# ===========================================
# Optional deploy verification endpoints
# ===========================================
VERIFY_BASE_URL=https://www.xyan.store
VERIFY_API_HEALTH_URL=https://www.xyan.store/api/health
VERIFY_HOME_URL=https://www.xyan.store/
VERIFY_LOGIN_URL=https://www.xyan.store/login
# Optional: configure paths that exist in your production content
VERIFY_POST_PATH=
VERIFY_UPLOAD_PATH=
# Optional: configure one authenticated write-check endpoint for deploy verification
VERIFY_WRITE_URL=
VERIFY_WRITE_METHOD=POST
VERIFY_WRITE_EXPECT=200,201,204
VERIFY_WRITE_BODY=
VERIFY_WRITE_BEARER_TOKEN=
