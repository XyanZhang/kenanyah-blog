# Web Dockerfile - Next.js standalone build
FROM node:20-alpine AS builder

WORKDIR /app
# Use a registry mirror in restricted networks (e.g. CN servers)
ENV NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# Install pnpm without corepack (more reliable behind firewalls)
RUN npm config set registry https://registry.npmmirror.com \
  && npm i -g pnpm@9.15.4 \
  && pnpm config set registry https://registry.npmmirror.com

WORKDIR /app
# Copy workspace config
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json ./
COPY packages ./packages
COPY apps/web ./apps/web
# Install dependencies
RUN pnpm --filter web install --frozen-lockfile
# Build (skip type check for tsc)
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter web exec tsc --noEmit || true
RUN pnpm --filter web build && test -d /app/apps/web/.next/static && test -d /app/apps/web/.next/standalone

# Production stage
FROM node:20-alpine AS runner
WORKDIR /app
# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs
# Copy built files
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
# Set environment
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
USER nextjs
EXPOSE 3000
WORKDIR /app/apps/web
CMD ["node", "server.js"]
